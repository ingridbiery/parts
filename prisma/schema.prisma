generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Part {
  id          Int         @id @default(autoincrement())
  partNumber  String      @unique
  name        String
  inventory   Inventory?
  orders      Order[]
}

model Inventory {
  id         Int    @id @default(autoincrement())
  quantity   Int
  part       Part   @relation(fields: [partId], references: [id])
  partId     Int    @unique
}

model Order {
  id            Int      @id @default(autoincrement())
  orderedAmount Int
  status        String   @default("PENDING") // PENDING, PROCESSING, SHIPPING, ARRIVED
  part          Part     @relation(fields: [partId], references: [id])
  partId        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}